# Copy this file to play-signing.properties. The real file is ignored by Git.
# This is used only for the public playRelease variant.
# storeFile may be an absolute path or a path relative to mobile/calllog-android/.
storeFile=/absolute/path/to/relationship-manager-play-upload.jks
storeSecret=CHANGE_ME
keyAlias=relationship-manager-play-upload
keySecret=CHANGE_ME
