<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_CALL_LOG" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.WRITE_CONTACTS" />
    <uses-permission android:name="android.permission.WRITE_SYNC_SETTINGS" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CallLog">
        <provider
            android:name=".DebugDefaultsProvider"
            android:authorities="${applicationId}.debugdefaults"
            android:exported="false"
            android:initOrder="1" />
        <service
            android:name=".CallReportAuthenticatorService"
            android:exported="true"
            android:permission="android.permission.BIND_ACCOUNT_AUTHENTICATOR">
            <intent-filter>
                <action android:name="android.accounts.AccountAuthenticator" />
            </intent-filter>
            <meta-data
                android:name="android.accounts.AccountAuthenticator"
                android:resource="@xml/callreport_authenticator" />
        </service>
        <service
            android:name=".CallReportSyncService"
            android:exported="true"
            android:permission="android.permission.BIND_SYNC_ADAPTER">
            <intent-filter>
                <action android:name="android.content.SyncAdapter" />
            </intent-filter>
            <meta-data
                android:name="android.content.SyncAdapter"
                android:resource="@xml/callreport_syncadapter" />
            <meta-data
                android:name="android.provider.CONTACTS_STRUCTURE"
                android:resource="@xml/callreport_contacts" />
        </service>
        <service
            android:name=".CallReportTileService"
            android:exported="true"
            android:icon="@drawable/ic_qs_callreport"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
            <meta-data
                android:name="android.service.quicksettings.TOGGLEABLE_TILE"
                android:value="false" />
        </service>
        <service
            android:name=".PostCallOverlayService"
            android:exported="false" />
        <receiver
            android:name=".NotificationDismissReceiver"
            android:enabled="true"
            android:exported="false" />
        <receiver
            android:name=".NoteEditorReceiver"
            android:enabled="true"
            android:exported="false" />
        <receiver
            android:name=".InlineNoteReplyReceiver"
            android:enabled="true"
            android:exported="false" />
        <receiver
            android:name=".BulkContactsCancelReceiver"
            android:enabled="true"
            android:exported="false" />
        <receiver
            android:name=".CallStateReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.PHONE_STATE" />
            </intent-filter>
        </receiver>
        <service
            android:name=".CallScreeningBridgeService"
            android:exported="true"
            android:permission="android.permission.BIND_SCREENING_SERVICE">
            <intent-filter>
                <action android:name="android.telecom.CallScreeningService" />
            </intent-filter>
        </service>
        <activity
            android:name=".NoteEditorLaunchActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="singleTop"
            android:noHistory="true"
            android:theme="@style/Theme.CallLog.TransparentLauncher" />
        <activity
            android:name=".SystemCallHistoryActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:noHistory="true" />
        <activity
            android:name=".PostCallPromptActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="singleTop" />
        <activity
            android:name=".ContactShareActivity"
            android:excludeFromRecents="true"
            android:exported="true"
            android:label="@string/app_name"
            android:noHistory="true">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/vcard" />
                <data android:mimeType="text/x-vcard" />
                <data android:mimeType="text/plain" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/vcard" />
                <data android:mimeType="text/x-vcard" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>
        <activity
            android:name=".PhoneNumberActionActivity"
            android:excludeFromRecents="true"
            android:exported="true"
            android:label="@string/app_name"
            android:noHistory="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="tel" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.DIAL" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="tel" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.WEB_SEARCH" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEARCH" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="www.google.com" android:pathPrefix="/search" />
                <data android:scheme="https" android:host="google.com" android:pathPrefix="/search" />
                <data android:scheme="https" android:host="www.google.bg" android:pathPrefix="/search" />
                <data android:scheme="https" android:host="google.bg" android:pathPrefix="/search" />
                <data android:scheme="https" android:host="www.google.de" android:pathPrefix="/search" />
                <data android:scheme="https" android:host="google.de" android:pathPrefix="/search" />
                <data android:scheme="http" android:host="www.google.com" android:pathPrefix="/search" />
                <data android:scheme="http" android:host="google.com" android:pathPrefix="/search" />
                <data android:scheme="http" android:host="www.google.bg" android:pathPrefix="/search" />
                <data android:scheme="http" android:host="google.bg" android:pathPrefix="/search" />
                <data android:scheme="http" android:host="www.google.de" android:pathPrefix="/search" />
                <data android:scheme="http" android:host="google.de" android:pathPrefix="/search" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="vnd.android.cursor.item/vnd.com.onlineimoti.calllog.history" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ContactNoteEditActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize|stateAlwaysVisible" />
        <activity
            android:name=".ContactNotesActivity"
            android:exported="false" />
        <activity
            android:name=".RecentCallsActivity"
            android:exported="false" />
        <activity
            android:name=".WebViewActivity"
            android:exported="false" />
        <activity
            android:name=".MainActivity"
            android:exported="false" />
        <activity
            android:name=".HomeActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
