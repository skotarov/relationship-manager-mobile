<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Core Relationship Manager permissions. Contacts access is only used for the optional contact link. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_CALL_LOG" />
    <uses-permission android:name="android.permission.READ_SMS" />
    <!-- Required by the existing SMS sender and incoming default-SMS delivery callback. -->
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.WRITE_SMS" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.WRITE_CONTACTS" />
    <!-- Optional shared Documents/.callreport storage. The app still works without it via private local notes. -->
    <uses-permission
        android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />
    <!-- Optional post-call UI. It is off by default and never required for the core call log. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Telephony-based features are unavailable on ChromeOS/tablets but must not block installation. -->
    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_identity"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CallLog"
        android:usesCleartextTraffic="false">
        <service
            android:name=".CallReportAuthenticatorService"
            android:exported="true"
            android:permission="android.permission.BIND_ACCOUNT_AUTHENTICATOR">
            <intent-filter>
                <action android:name="android.accounts.AccountAuthenticator" />
            </intent-filter>
            <meta-data
                android:name="android.accounts.AccountAuthenticator"
                android:resource="@xml/callreport_authenticator" />
        </service>
        <service
            android:name=".CallReportSyncService"
            android:exported="true"
            android:permission="android.permission.BIND_SYNC_ADAPTER">
            <intent-filter>
                <action android:name="android.content.SyncAdapter" />
            </intent-filter>
            <meta-data
                android:name="android.accounts.AccountAuthenticator"
                android:resource="@xml/callreport_authenticator" />
            <meta-data
                android:name="android.provider.CONTACTS_STRUCTURE"
                android:resource="@xml/callreport_contacts" />
        </service>
        <service
            android:name=".CallReportTileService"
            android:exported="true"
            android:icon="@drawable/ic_qs_callreport"
            android:label="@string/app_identity"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
            <meta-data
                android:name="android.service.quicksettings.TOGGLEABLE_TILE"
                android:value="false" />
        </service>
        <service
            android:name=".PostCallOverlayService"
            android:exported="false" />

        <receiver
            android:name=".NotificationDismissReceiver"
            android:enabled="true"
            android:exported="false" />
        <receiver
            android:name=".NoteEditorReceiver"
            android:enabled="true"
            android:exported="false" />
        <receiver
            android:name=".InlineNoteReplyReceiver"
            android:enabled="true"
            android:exported="false" />
        <receiver
            android:name=".BulkContactsCancelReceiver"
            android:enabled="true"
            android:exported="false" />
        <!-- Default-SMS delivery: notification actions reuse the current SMS list and composer. -->
        <receiver
            android:name=".SmsDeliverReceiver"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter>
                <action android:name="android.provider.Telephony.SMS_DELIVER" />
            </intent-filter>
        </receiver>
        <receiver
            android:name=".CallStateReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.PHONE_STATE" />
            </intent-filter>
        </receiver>

        <service
            android:name=".CallScreeningBridgeService"
            android:exported="true"
            android:permission="android.permission.BIND_SCREENING_SERVICE">
            <intent-filter>
                <action android:name="android.telecom.CallScreeningService" />
            </intent-filter>
        </service>

        <!-- Internal launch targets used by post-call notifications and the end-call bubble. -->
        <activity
            android:name=".NoteEditorLaunchActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="singleTop"
            android:noHistory="true"
            android:theme="@style/Theme.CallLog.TransparentLauncher" />
        <activity
            android:name=".SystemCallHistoryActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:noHistory="true" />
        <activity
            android:name=".PostCallPromptActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="singleTop" />
        <activity
            android:name=".ContactNoteEditActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize|stateAlwaysVisible" />
        <activity
            android:name=".ServerNoteEditActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize|stateAlwaysVisible" />
        <activity
            android:name=".ContactNotesActivity"
            android:exported="false" />
        <activity
            android:name=".SmsHistoryActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <!-- A tap on the phone's messaging entry opens SMS, not the call-log home screen. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.APP_MESSAGING" />
            </intent-filter>
        </activity>
        <activity
            android:name=".RecentCallsActivity"
            android:exported="false" />
        <activity
            android:name=".WebViewActivity"
            android:exported="false" />
        <activity
            android:name=".CompanyLicenseActivity"
            android:exported="false" />
        <activity
            android:name=".CompanyAccountActivity"
            android:exported="false" />

        <activity
            android:name=".ContactShareActivity"
            android:excludeFromRecents="true"
            android:exported="true"
            android:label="@string/app_identity"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/vcard" />
                <data android:mimeType="text/x-vcard" />
                <data android:mimeType="application/vcard" />
                <data android:mimeType="application/x-vcard" />
                <data android:mimeType="text/directory" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/vcard" />
                <data android:mimeType="text/x-vcard" />
                <data android:mimeType="application/vcard" />
                <data android:mimeType="application/x-vcard" />
                <data android:mimeType="text/directory" />
            </intent-filter>
            <!-- This handles content-provider vCard documents, not web/App Links. -->
            <intent-filter tools:ignore="AppLinkUrlError">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/vcard" />
                <data android:mimeType="text/x-vcard" />
                <data android:mimeType="application/vcard" />
                <data android:mimeType="application/x-vcard" />
                <data android:mimeType="text/directory" />
            </intent-filter>
        </activity>
        <activity
            android:name=".PhoneNumberActionActivity"
            android:excludeFromRecents="true"
            android:exported="true"
            android:label="@string/dial_handler_label"
            android:noHistory="true">
            <!-- Custom contact MIME type only; this is not an HTTP deep link. -->
            <intent-filter tools:ignore="AppLinkUrlError">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="vnd.android.cursor.item/vnd.com.onlineimoti.calllog.history" />
            </intent-filter>
        </activity>
        <activity
            android:name=".HomeActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".MainActivity"
            android:exported="false" />
    </application>
</manifest>
