<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="16dp"
    app:cardBackgroundColor="@color/calllog_surface"
    app:cardCornerRadius="18dp"
    app:cardElevation="1dp"
    app:strokeColor="@color/calllog_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="10dp"
                android:contentDescription="@string/settings_general_section"
                android:src="@drawable/ic_settings_application" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/settings_general_section"
                android:textColor="@color/calllog_text"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <include
            android:id="@+id/languageSettingsSection"
            layout="@layout/section_language_settings" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/font_scale_title"
            android:textColor="@color/calllog_text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/fontScaleGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/fontScaleNormalRadio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/font_scale_normal"
                android:textColor="@color/calllog_text"
                android:textSize="15sp" />

            <RadioButton
                android:id="@+id/fontScaleLargerRadio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/font_scale_larger"
                android:textColor="@color/calllog_text"
                android:textSize="15sp" />

            <RadioButton
                android:id="@+id/fontScaleLargestRadio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/font_scale_largest"
                android:textColor="@color/calllog_text"
                android:textSize="15sp" />
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="2dp"
            android:text="@string/font_scale_description"
            android:textColor="@color/calllog_muted_text"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/buildVersionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="@color/calllog_muted_text"
            android:textSize="12sp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
