<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Съхранение на бележките"
        android:textColor="@color/calllog_text"
        android:textSize="16sp"
        android:textStyle="bold" />

    <CheckBox
        android:id="@+id/usePublicNotesFolderCheckBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:checked="true"
        android:text="Използвай обща файлова система — Documents/.callreport" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Включено: бележките са в обща папка и Android може да поиска All files access. Изключено: бележките се пазят само във вътрешната памет на приложението и не се иска достъп до общата файлова система."
        android:textColor="@color/calllog_muted_text"
        android:textSize="13sp" />
</LinearLayout>