<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="18dp"
    android:background="@drawable/bg_server_test_section"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Тест на сървъра"
        android:textColor="@color/calllog_text"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Използва текущите Base URL, Access token и пътища от Server settings. Тестовият номер и посоката са отгоре."
        android:textColor="@color/calllog_muted_text"
        android:textSize="13sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/testServerAllButton"
        style="@style/Widget.Material3.Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Тествай всички безопасни функции" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/testServerConfigButton"
            style="@style/Widget.Material3.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Config" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/testServerLookupButton"
            style="@style/Widget.Material3.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Lookup" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/testServerNotesButton"
            style="@style/Widget.Material3.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Бележки" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/testServerHistoryLookupButton"
            style="@style/Widget.Material3.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="History API" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/testServerPropertySearchButton"
            style="@style/Widget.Material3.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Обяви" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="Страници във WebView"
        android:textColor="@color/calllog_text"
        android:textSize="14sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/testServerFormButton"
            style="@style/Widget.Material3.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Отвори form.php" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/testServerHistoryButton"
            style="@style/Widget.Material3.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Отвори history.php" />
    </LinearLayout>

    <CheckBox
        android:id="@+id/allowServerWriteTestsCheckBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="Разреши тестови записи на сървъра (sync и submit)" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="При включване двата теста създават или обновяват ясно означени [TEST] записи към тестовия номер."
        android:textColor="@color/calllog_muted_text"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/testServerSyncButton"
            style="@style/Widget.Material3.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Тест sync.php" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/testServerSubmitButton"
            style="@style/Widget.Material3.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Тест submit.php" />
    </LinearLayout>

    <TextView
        android:id="@+id/serverTestResultsText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_server_test_results"
        android:fontFamily="monospace"
        android:padding="10dp"
        android:text="Няма изпълнен тест."
        android:textColor="@color/calllog_muted_text"
        android:textIsSelectable="true"
        android:textSize="12sp" />
</LinearLayout>
