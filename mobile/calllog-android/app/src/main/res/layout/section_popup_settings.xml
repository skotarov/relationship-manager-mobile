<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="@string/popup_timeout_hint"
        app:boxBackgroundColor="@android:color/white"
        app:boxStrokeColor="@color/calllog_border">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/postCallTimeoutInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:inputType="number"
            android:text="10" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/popup_after_call_title"
        android:textColor="@color/calllog_text"
        android:textSize="16sp"
        android:textStyle="bold" />

    <RadioGroup
        android:id="@+id/postCallEndActionGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/postCallEndActionEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/popup_action_edit_note" />

        <RadioButton
            android:id="@+id/postCallEndActionHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/popup_action_history_screen" />

        <RadioButton
            android:id="@+id/postCallEndActionNothing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/popup_action_nothing" />
    </RadioGroup>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="@string/popup_after_call_description"
        android:textColor="@color/calllog_muted_text"
        android:textSize="13sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/popup_type_title"
        android:textColor="@color/calllog_text"
        android:textSize="16sp"
        android:textStyle="bold" />

    <CheckBox
        android:id="@+id/useOverlayPopupsCheckBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:checked="false"
        android:text="@string/popup_use_overlay" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="@string/popup_overlay_description"
        android:textColor="@color/calllog_muted_text"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/overlayPermissionWarningText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/popup_overlay_warning"
        android:textColor="@color/calllog_error"
        android:textSize="13sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/overlayPopupOptionsGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <CheckBox
            android:id="@+id/useCustomStartPopupCheckBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:checked="true"
            android:text="@string/popup_custom_start" />

        <CheckBox
            android:id="@+id/useCustomEndPopupCheckBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="@string/popup_custom_end" />
    </LinearLayout>
</LinearLayout>