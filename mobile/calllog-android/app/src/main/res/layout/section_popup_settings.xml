<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Секунди за auto-close на popup след край">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/postCallTimeoutInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="10" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="След приключване на разговора"
        android:textColor="@color/calllog_text"
        android:textSize="16sp"
        android:textStyle="bold" />

    <RadioGroup
        android:id="@+id/postCallEndActionGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/postCallEndActionEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Едит бележка" />

        <RadioButton
            android:id="@+id/postCallEndActionHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="История екран" />

        <RadioButton
            android:id="@+id/postCallEndActionNothing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Нищо" />
    </RadioGroup>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="При overlay режим се показва малко бутонче, което отваря избраното действие. При системен режим действието се отваря директно."
        android:textColor="@color/calllog_muted_text"
        android:textSize="13sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Вид на popup-ите"
        android:textColor="@color/calllog_text"
        android:textSize="16sp"
        android:textStyle="bold" />

    <CheckBox
        android:id="@+id/useOverlayPopupsCheckBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:checked="false"
        android:text="Използвай Display over other apps / overlay popup-и" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="По подразбиране е изключено. Когато е изключено или липсва разрешение, първият popup е системен, а редакциите се отварят на цял екран."
        android:textColor="@color/calllog_muted_text"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/overlayPermissionWarningText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Overlay popup-ите са избрани, но Android разрешението липсва. Реално ще се показва системен popup, докато не разрешиш Display over other apps."
        android:textColor="@color/calllog_error"
        android:textSize="13sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/overlayPopupOptionsGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <CheckBox
            android:id="@+id/useCustomStartPopupCheckBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:checked="true"
            android:text="Първият popup да е custom overlay" />

        <CheckBox
            android:id="@+id/useCustomEndPopupCheckBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="Финалният popup да е custom floating иконка" />
    </LinearLayout>
</LinearLayout>
