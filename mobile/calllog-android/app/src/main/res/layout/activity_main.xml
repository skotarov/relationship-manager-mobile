<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/calllog_bg"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/calllog_bg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/backToHomeButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/settings_back_content_description"
                    android:gravity="center"
                    android:text="←"
                    android:textColor="@color/calllog_text"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="@string/settings_title"
                    android:textColor="@color/calllog_text"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_description"
                android:textColor="@color/calllog_muted_text"
                android:textSize="15sp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:cardBackgroundColor="@color/calllog_surface"
                app:cardCornerRadius="18dp"
                app:cardElevation="1dp"
                app:strokeColor="@color/calllog_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_basic_section"
                        android:textColor="@color/calllog_text"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <include
                        android:id="@+id/storageSettingsSection"
                        layout="@layout/section_storage_settings" />

                    <include
                        android:id="@+id/contactFilterSection"
                        layout="@layout/section_contact_filter" />

                    <include
                        android:id="@+id/contactLinkSection"
                        layout="@layout/section_contact_link" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/calllog_surface"
                app:cardCornerRadius="18dp"
                app:cardElevation="1dp"
                app:strokeColor="@color/calllog_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_popup_section"
                        android:textColor="@color/calllog_text"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <include
                        android:id="@+id/popupSettingsSection"
                        layout="@layout/section_popup_settings" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/calllog_surface"
                app:cardCornerRadius="18dp"
                app:cardElevation="1dp"
                app:strokeColor="@color/calllog_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_permissions_section"
                        android:textColor="@color/calllog_text"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <include
                        android:id="@+id/permissionsSection"
                        layout="@layout/section_permissions" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/calllog_surface"
                app:cardCornerRadius="18dp"
                app:cardElevation="1dp"
                app:strokeColor="@color/calllog_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_server_section"
                        android:textColor="@color/calllog_text"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <include
                        android:id="@+id/remoteSettingsSection"
                        layout="@layout/section_remote_settings" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/calllog_surface"
                app:cardCornerRadius="18dp"
                app:cardElevation="1dp"
                app:strokeColor="@color/calllog_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_debug_section"
                        android:textColor="@color/calllog_text"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/settings_debug_description"
                        android:textColor="@color/calllog_muted_text"
                        android:textSize="13sp" />

                    <include
                        android:id="@+id/testsSection"
                        layout="@layout/section_tests" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/calllog_muted_text"
                android:textSize="14sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/buildVersionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textColor="@color/calllog_muted_text"
                android:textSize="12sp" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/quickTestBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/calllog_surface"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="8dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/testStartPopupButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/test_start_popup" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/testEndPopupButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/test_end_popup" />
    </LinearLayout>
</LinearLayout>