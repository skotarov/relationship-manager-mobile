<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/calllog_bg"
    android:orientation="vertical">

    <ScrollView
        android:id="@+id/settingsScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/calllog_bg">

        <LinearLayout
            android:id="@+id/settingsContentRoot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:id="@+id/settingsTopHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <ImageButton
                    android:id="@+id/backToHomeButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/settings_back_content_description"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_settings_back" />
                <TextView
                    android:id="@+id/settingsMainTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="@string/settings_title"
                    android:textColor="@color/calllog_text"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/settingsDescriptionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_description"
                android:textColor="@color/calllog_muted_text"
                android:textSize="15sp" />

            <include
                android:id="@+id/settingsMenuGroup"
                layout="@layout/settings_group_menu" />

            <LinearLayout
                android:id="@+id/settingsDetailHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">
                <ImageButton
                    android:id="@+id/settingsDetailBackButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/settings_back_content_description"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_settings_back" />
                <TextView
                    android:id="@+id/settingsDetailTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:textColor="@color/calllog_text"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <include
                android:id="@+id/settingsApplicationGroup"
                layout="@layout/settings_group_application" />

            <include
                android:id="@+id/settingsPopupGroup"
                layout="@layout/settings_group_popup" />

            <include
                android:id="@+id/settingsRmContactsGroup"
                layout="@layout/settings_group_rm_contacts" />

            <include
                android:id="@+id/settingsServerGroup"
                layout="@layout/settings_group_server" />

            <include
                android:id="@+id/settingsRegistrationGroup"
                layout="@layout/settings_group_registration" />

            <include
                android:id="@+id/settingsDataArchiveGroup"
                layout="@layout/settings_group_data_archive" />

            <include
                android:id="@+id/settingsGeneralGroup"
                layout="@layout/settings_group_general" />

            <include
                android:id="@+id/settingsDebugGroup"
                layout="@layout/settings_group_debug" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/calllog_muted_text"
                android:textSize="14sp"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/quickTestBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/calllog_surface"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="8dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp"
        android:visibility="gone">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/testStartPopupButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/test_start_popup" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/testEndPopupButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/test_end_popup" />
    </LinearLayout>
</LinearLayout>
