<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/calllog_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Call Report"
            android:textColor="@color/calllog_text"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Настройки на Android wrapper-а за call popup-и, локална история и server WebView форма."
            android:textColor="@color/calllog_muted_text"
            android:textSize="15sp" />

        <CheckBox
            android:id="@+id/remoteEnabledCheckBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:checked="true"
            android:text="Сървър" />

        <LinearLayout
            android:id="@+id/remoteSettingsGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Base URL">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/baseUrlInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:text="https://onlineimoti.com" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Access token">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/accessTokenInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textNoSuggestions" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Път до lookup файла">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/lookupPathInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:text="/broker/callreport/lookup.php" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Път до form файла">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/formPathInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:text="/broker/callreport/form.php" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Път до full/history log файла">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/historyPathInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:text="/broker/callreport/history.php" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Секунди за auto-close на popup след край">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/postCallTimeoutInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="10" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Вид на popup-ите"
            android:textColor="@color/calllog_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <CheckBox
            android:id="@+id/useCustomStartPopupCheckBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:checked="true"
            android:text="Първият popup да е custom overlay" />

        <CheckBox
            android:id="@+id/useCustomEndPopupCheckBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="Финалният popup да е custom floating иконка" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="CRM свързване в Android контакти"
            android:textColor="@color/calllog_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/contactLinkModeGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="vertical">
            <RadioButton
                android:id="@+id/contactLinkModeApp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="Като приложение — Call Report да се показва в свързани приложения" />
            <RadioButton
                android:id="@+id/contactLinkModeContact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Като контакт — Call Report да се добавя като свързан контакт" />
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Смяната важи при следващо Добави/Премахни от CRM."
            android:textColor="@color/calllog_muted_text"
            android:textSize="13sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="За кои номера да се показва popup"
            android:textColor="@color/calllog_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <CheckBox
            android:id="@+id/notifyUnknownContactsCheckBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:checked="true"
            android:text="Непознати номера" />

        <CheckBox
            android:id="@+id/notifyKnownContactsCheckBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Познати контакти" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Групи за познати контакти">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/contactGroupsInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textNoSuggestions"
                android:maxLines="2" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Ако „Познати контакти“ е включено: празно поле = всички познати; попълнено = само контактите от тези групи."
            android:textColor="@color/calllog_muted_text"
            android:textSize="13sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Статус на разрешенията"
            android:textColor="@color/calllog_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/permissionsSummaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/calllog_muted_text"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/openAppPermissionsButton"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Отвори Permissions" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/openCallScreeningButton"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Активирай Call screening" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/openFullscreenIntentButton"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Разреши Full-screen popup" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/cleanupContactsButton"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Почисти Call Report от контактите" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="@color/calllog_surface"
            app:cardCornerRadius="18dp"
            app:cardElevation="1dp"
            app:strokeColor="@color/calllog_border"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Тестове"
                    android:textColor="@color/calllog_text"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Телефон за тест">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/phoneInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="phone"
                        android:text="0876442321" />
                </com.google.android.material.textfield.TextInputLayout>
                <RadioGroup
                    android:id="@+id/directionGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">
                    <RadioButton
                        android:id="@+id/directionIn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Входящо" />
                    <RadioButton
                        android:id="@+id/directionOut"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="18dp"
                        android:checked="true"
                        android:text="Изходящо" />
                </RadioGroup>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/testStartPopupButton"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Тест: popup при старт" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/testEndPopupButton"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Тест: popup след край" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/testFullLogButton"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Тест: пълен лог" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/openFormButton"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/open_form_direct" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/saveSettingsButton"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/save_settings" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="@color/calllog_muted_text"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/buildVersionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:gravity="center"
            android:textColor="@color/calllog_muted_text"
            android:textSize="12sp" />

    </LinearLayout>
</ScrollView>
