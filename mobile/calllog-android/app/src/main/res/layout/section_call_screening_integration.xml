<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/call_screening_integration_title"
        android:textColor="@color/calllog_text"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/callScreeningIntegrationStatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_settings_info"
        android:paddingStart="12dp"
        android:paddingTop="9dp"
        android:paddingEnd="12dp"
        android:paddingBottom="9dp"
        android:textColor="@color/calllog_text"
        android:textSize="14sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/callScreeningIntegrationButton"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:minHeight="46dp"
        android:text="@string/call_screening_integration_activate"
        app:icon="@drawable/ic_settings_permissions"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        app:iconTint="@color/calllog_text"
        app:strokeColor="@color/calllog_border"
        app:strokeWidth="1dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="@string/call_screening_integration_description"
        android:textColor="@color/calllog_muted_text"
        android:textSize="13sp" />
</LinearLayout>
