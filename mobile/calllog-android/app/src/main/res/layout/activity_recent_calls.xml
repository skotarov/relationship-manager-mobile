<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/calllog_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/recentCallsTitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Последни разговори"
        android:textColor="@color/calllog_text"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/recentCallsStatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/calllog_muted_text"
        android:textSize="14sp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/recentCallsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>
</LinearLayout>