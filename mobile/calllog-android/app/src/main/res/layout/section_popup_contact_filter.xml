<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/popup_contact_filter_title"
        android:textColor="@color/calllog_text"
        android:textSize="16sp"
        android:textStyle="bold" />

    <CheckBox
        android:id="@+id/notifyUnknownContactsCheckBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:checked="true"
        android:text="@string/notify_unknown_contacts" />

    <CheckBox
        android:id="@+id/notifyKnownContactsCheckBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/notify_known_contacts" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="@string/contact_groups_hint"
        app:boxBackgroundColor="@android:color/white"
        app:boxStrokeColor="@color/calllog_border">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/contactGroupsInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:inputType="textNoSuggestions"
            android:maxLines="2" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/contact_groups_description"
        android:textColor="@color/calllog_muted_text"
        android:textSize="13sp" />
</LinearLayout>