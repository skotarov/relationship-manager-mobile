<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="@string/home_call_page_size_hint"
        app:boxBackgroundColor="@android:color/white"
        app:boxStrokeColor="@color/calllog_border">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/homeCallPageSizeInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:inputType="number"
            android:text="20" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/home_call_page_size_description"
        android:textColor="@color/calllog_muted_text"
        android:textSize="13sp" />

    <CheckBox
        android:id="@+id/useCallLogOverlayButtonCheckBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:checked="true"
        android:text="@string/call_log_overlay_button_enabled" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="@string/call_log_overlay_button_description"
        android:textColor="@color/calllog_muted_text"
        android:textSize="13sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/call_log_overlay_button_position_title"
        android:textColor="@color/calllog_text"
        android:textSize="15sp"
        android:textStyle="bold" />

    <RadioGroup
        android:id="@+id/callLogOverlayButtonPositionGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/callLogOverlayPositionTopEnd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/call_log_overlay_position_top_end" />

        <RadioButton
            android:id="@+id/callLogOverlayPositionTopStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/call_log_overlay_position_top_start" />

        <RadioButton
            android:id="@+id/callLogOverlayPositionBottomEnd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/call_log_overlay_position_bottom_end" />

        <RadioButton
            android:id="@+id/callLogOverlayPositionBottomStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/call_log_overlay_position_bottom_start" />
    </RadioGroup>
</LinearLayout>
