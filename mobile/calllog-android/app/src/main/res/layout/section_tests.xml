<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="@string/test_phone_hint"
        app:boxBackgroundColor="@android:color/white"
        app:boxStrokeColor="@color/calllog_border">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/phoneInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:inputType="phone"
            android:text="0876442321" />
    </com.google.android.material.textfield.TextInputLayout>

    <RadioGroup
        android:id="@+id/directionGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">
        <RadioButton
            android:id="@+id/directionIn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/direction_incoming" />
        <RadioButton
            android:id="@+id/directionOut"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:checked="true"
            android:text="@string/direction_outgoing" />
    </RadioGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/testStartPopupButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/test_start_popup" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/testEndPopupButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/test_end_popup" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/openFormButton"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/open_form_php" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/testFullLogButton"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/open_history_php" />
</LinearLayout>