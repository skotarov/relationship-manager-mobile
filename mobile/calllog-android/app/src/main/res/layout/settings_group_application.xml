<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="18dp"
    app:cardBackgroundColor="@color/calllog_surface"
    app:cardCornerRadius="18dp"
    app:cardElevation="1dp"
    app:strokeColor="@color/calllog_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="10dp"
                android:contentDescription="@string/settings_application_section"
                android:src="@drawable/ic_settings_application" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/settings_application_section"
                android:textColor="@color/calllog_text"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/settings_language_section"
            android:textColor="@color/calllog_text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <include
            android:id="@+id/languageSettingsSection"
            layout="@layout/section_language_settings" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Основни функции"
            android:textColor="@color/calllog_text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <CheckBox
            android:id="@+id/applicationUsePublicNotesFolderCheckBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:checked="true"
            android:text="Пиши бележките в shared файловата система" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Същата настройка остава и в Storage/Data archive секцията."
            android:textColor="@color/calllog_muted_text"
            android:textSize="13sp" />

        <CheckBox
            android:id="@+id/applicationUseOverlayPopupsCheckBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:checked="false"
            android:text="Използвай custom popup-и върху други приложения" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Същата настройка остава и в Popup секцията. При включване ще поиска Display over other apps."
            android:textColor="@color/calllog_muted_text"
            android:textSize="13sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/settings_permissions_section"
            android:textColor="@color/calllog_text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <include
            android:id="@+id/permissionsSection"
            layout="@layout/section_permissions" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
