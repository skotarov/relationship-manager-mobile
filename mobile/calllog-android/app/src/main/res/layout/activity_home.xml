<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/calllog_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout style="@style/RelationshipManagerHomeHorizontalRow">
        <com.onlineimoti.calllog.RelationshipManagerWordmarkView
            android:id="@+id/relationshipManagerWordmark"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:adjustViewBounds="true"
            android:contentDescription="@string/home_title"
            android:scaleType="fitStart"
            android:src="@drawable/relationship_manager_wordmark" />

        <LinearLayout
            android:id="@+id/crmContactsHeader"
            style="@style/RelationshipManagerHomeHorizontalRow"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:visibility="gone">

            <ImageButton
                android:id="@+id/crmContactsBackButton"
                style="@style/RelationshipManagerHomeBackAction"
                android:contentDescription="@string/settings_back_content_description"
                android:src="@drawable/ic_arrow_back" />

            <TextView
                android:id="@+id/crmContactsTitleText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="CRM Contacts"
                android:textColor="@color/calllog_text"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/searchButton"
            style="@style/RelationshipManagerHomeHeaderAction"
            android:layout_marginEnd="4dp"
            android:contentDescription="@string/search_content_description"
            android:src="@drawable/ic_search" />

        <ImageButton
            android:id="@+id/settingsButton"
            style="@style/RelationshipManagerHomeHeaderAction"
            android:contentDescription="@string/home_overflow_menu_content_description"
            android:src="@drawable/ic_more_vert" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/searchRow"
        style="@style/RelationshipManagerHomeHorizontalRow"
        android:layout_marginTop="10dp"
        android:visibility="gone">

        <EditText
            android:id="@+id/searchInput"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@android:color/white"
            android:hint="@string/search_hint"
            android:inputType="textCapSentences"
            android:maxLines="1"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="@color/calllog_text"
            android:textColorHint="@color/calllog_muted_text"
            android:textSize="15sp" />

        <ImageButton
            android:id="@+id/clearSearchButton"
            style="@style/RelationshipManagerHomeClearSearchAction"
            android:layout_marginStart="6dp"
            android:contentDescription="@string/search_clear_content_description"
            android:src="@drawable/ic_popup_close" />
    </LinearLayout>

    <TextView
        android:id="@+id/searchStatusText"
        android:layout_width="match_parent"
        android:layout_height="16dp"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:maxLines="1"
        android:textColor="@color/calllog_muted_text"
        android:textSize="11sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/homeStatusRow"
        style="@style/RelationshipManagerHomeHorizontalRow"
        android:layout_marginTop="8dp">

        <ImageButton
            android:id="@+id/clearFilterButton"
            style="@style/RelationshipManagerHomeClearFilterAction"
            android:layout_marginEnd="4dp"
            android:contentDescription="@string/clear_filter_content_description"
            android:src="@drawable/ic_filter_clear"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/filteredStatusContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/homeStatusText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/calllog_muted_text"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/crmCompanyFilterButton"
                    style="@style/RelationshipManagerHomeCompanyFilterButton"
                    android:text="@string/crm_filter_companies_all"
                    android:visibility="gone" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/fullLogProgress"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="4dp"
                android:indeterminate="true"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/filteredDialButton"
                style="@style/RelationshipManagerHomeFilteredDialAction"
                android:contentDescription="@string/dynamic_action_call"
                android:src="@drawable/ic_phone_call"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/crmPhaseFilterRow"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/crmPhase1Button"
            style="@style/RelationshipManagerHomePhaseButton"
            android:layout_marginEnd="2dp"
            android:text="@string/crm_phase_filter_1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/crmPhase2Button"
            style="@style/RelationshipManagerHomePhaseButton"
            android:layout_marginEnd="2dp"
            android:text="@string/crm_phase_filter_2" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/crmPhase3Button"
            style="@style/RelationshipManagerHomePhaseButton"
            android:layout_marginEnd="2dp"
            android:text="@string/crm_phase_filter_3" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/crmPhase4Button"
            style="@style/RelationshipManagerHomePhaseButton"
            android:text="@string/crm_phase_filter_4" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/filteredContactSummaryContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:visibility="gone" />

    <com.onlineimoti.calllog.PullToRefreshLayout
        android:id="@+id/homeCallsRefreshLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ScrollView
                android:id="@+id/homeCallsScrollView"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:id="@+id/homeCallsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </ScrollView>

            <TextView
                android:id="@+id/stickyGroupHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:ellipsize="end"
                android:maxLines="1"
                android:visibility="gone" />
        </FrameLayout>
    </com.onlineimoti.calllog.PullToRefreshLayout>

    <LinearLayout
        android:id="@+id/paginationContainer"
        style="@style/RelationshipManagerHomeHorizontalRow"
        android:layout_marginTop="10dp">

        <com.onlineimoti.calllog.HomePaginationButton
            android:id="@+id/previousCallsButton"
            style="@style/RelationshipManagerHomePaginationButton"
            android:text="@string/previous_20" />

        <TextView
            android:id="@+id/pageText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:textColor="@color/calllog_muted_text"
            android:textSize="13sp" />

        <com.onlineimoti.calllog.HomePaginationButton
            android:id="@+id/nextCallsButton"
            style="@style/RelationshipManagerHomePaginationButton"
            android:text="@string/next_20" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/homeBottomActionBar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="4dp"
        android:background="@color/calllog_bg"
        android:elevation="0dp"
        android:gravity="center"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/crmControlsScroll"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone">

            <com.onlineimoti.calllog.HomeCrmModeButton
                android:id="@+id/crmModeButton"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:contentDescription="@string/runtime_crm_clients"
                android:elevation="0dp"
                android:gravity="center"
                android:padding="14dp"
                android:stateListAnimator="@null"
                android:text=""
                app:icon="@drawable/ic_menu_contacts"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="24dp"
                app:iconTint="@color/calllog_text" />
        </LinearLayout>

        <com.onlineimoti.calllog.HomeDialPadButton
            android:id="@+id/dialPadButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:contentDescription="Клавиатура за набиране"
            android:elevation="0dp"
            android:padding="14dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_dial_pad"
            android:stateListAnimator="@null"
            android:tint="@color/calllog_text" />

        <ImageButton
            android:id="@+id/smsHistoryButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:contentDescription="@string/runtime_menu_sms"
            android:elevation="0dp"
            android:padding="14dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_menu_sms"
            android:stateListAnimator="@null"
            android:tint="@color/calllog_text" />
    </LinearLayout>
</LinearLayout>