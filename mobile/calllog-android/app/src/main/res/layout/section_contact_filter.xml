<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="За кои номера да се показва popup"
        android:textColor="@color/calllog_text"
        android:textSize="16sp"
        android:textStyle="bold" />

    <CheckBox
        android:id="@+id/notifyUnknownContactsCheckBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:checked="true"
        android:text="Непознати номера" />

    <CheckBox
        android:id="@+id/notifyKnownContactsCheckBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Познати контакти" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Групи за познати контакти">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/contactGroupsInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textNoSuggestions"
            android:maxLines="2" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Ако „Познати контакти“ е включено: празно поле = всички познати; попълнено = само контактите от тези групи."
        android:textColor="@color/calllog_muted_text"
        android:textSize="13sp" />
</LinearLayout>
