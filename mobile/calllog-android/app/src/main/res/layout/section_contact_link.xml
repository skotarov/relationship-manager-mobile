<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/contact_link_title"
        android:textColor="@color/calllog_text"
        android:textSize="16sp"
        android:textStyle="bold" />

    <CheckBox
        android:id="@+id/showCrmActionButtonsCheckBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:checked="true"
        android:text="@string/contact_link_show_crm_buttons" />

    <RadioGroup
        android:id="@+id/contactLinkModeGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="vertical">
        <RadioButton
            android:id="@+id/contactLinkModeApp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="@string/contact_link_mode_app" />
        <RadioButton
            android:id="@+id/contactLinkModeContact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/contact_link_mode_contact" />
    </RadioGroup>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/contact_link_description"
        android:textColor="@color/calllog_muted_text"
        android:textSize="13sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/contact_link_bulk_title"
        android:textColor="@color/calllog_text"
        android:textSize="15sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/contactLinkBulkActionsGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/registerAllContactsButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="46dp"
            android:text="@string/contact_link_register_all_button"
            app:icon="@drawable/ic_rm_bulk_register"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="@color/calllog_text"
            app:strokeColor="@color/calllog_accent"
            app:strokeWidth="1.5dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/debugCrmContactNameButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:minHeight="46dp"
            android:text="@string/contact_link_debug_button"
            app:icon="@drawable/ic_rm_bulk_repair"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="@color/calllog_text"
            app:strokeColor="@color/calllog_accent"
            app:strokeWidth="1.5dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cleanupOrphanContactsButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:minHeight="46dp"
            android:text="@string/contact_link_clean_orphans_button"
            app:icon="@drawable/ic_rm_bulk_clean_orphans"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="@color/calllog_text"
            app:strokeColor="@color/calllog_accent"
            app:strokeWidth="1.5dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cleanupContactsButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:minHeight="46dp"
            android:text="@string/permissions_cleanup_contacts_button"
            app:icon="@drawable/ic_rm_bulk_clean_all"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="@color/calllog_text"
            app:strokeColor="@color/calllog_accent"
            app:strokeWidth="1.5dp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/contact_link_bulk_description"
        android:textColor="@color/calllog_muted_text"
        android:textSize="13sp" />
</LinearLayout>