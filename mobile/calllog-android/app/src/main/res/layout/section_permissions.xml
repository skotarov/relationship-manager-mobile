<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/permissions_title"
        android:textColor="@color/calllog_text"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/permissionsSummaryText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/calllog_muted_text"
        android:textSize="13sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="SMS тема"
        android:textColor="@color/calllog_text"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Създава Xiaomi/HyperOS тема само за иконата на системното SMS приложение. Не добавя втора икона и не променя тапет, шрифт или други приложения."
        android:textColor="@color/calllog_muted_text"
        android:textSize="13sp"
        android:visibility="gone" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/openSmsThemeButton"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Инсталирай SMS тема"
        android:visibility="gone" />

    <CheckBox
        android:id="@+id/useCallScreeningCheckBox"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />
    <com.google.android.material.button.MaterialButton
        android:id="@+id/openAppPermissionsButton"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />
    <com.google.android.material.button.MaterialButton
        android:id="@+id/openOverlayPermissionButton"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />
    <com.google.android.material.button.MaterialButton
        android:id="@+id/openCallScreeningButton"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />
    <com.google.android.material.button.MaterialButton
        android:id="@+id/openSmsRoleButton"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />
    <com.google.android.material.button.MaterialButton
        android:id="@+id/openFullscreenIntentButton"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />
</LinearLayout>
