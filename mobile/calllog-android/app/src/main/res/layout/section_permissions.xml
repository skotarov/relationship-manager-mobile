<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Статус на разрешенията"
        android:textColor="@color/calllog_text"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/permissionsSummaryText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/calllog_muted_text"
        android:textSize="13sp" />

    <CheckBox
        android:id="@+id/useCallScreeningCheckBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:checked="false"
        android:text="Използвай Call screening / Caller ID роля" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Не е задължително. Активирай го само ако popup-ът не се показва навреме при входящ разговор или Android забавя информацията за разговора. Телефонът може да го покаже като Default caller ID / spam app."
        android:textColor="@color/calllog_muted_text"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="vertical">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/openAppPermissionsButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Отвори Permissions" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/openOverlayPermissionButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Разреши Display over other apps" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/openCallScreeningButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Активирай Call screening" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/openFullscreenIntentButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Разреши Full-screen popup" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/cleanupContactsButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Почисти Call Report от контактите" />
    </LinearLayout>
</LinearLayout>